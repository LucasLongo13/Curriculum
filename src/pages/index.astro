---
import Layout from '../layouts/Layout.astro';
import InteractiveHero from '../components/InteractiveHero.svelte';
---

<Layout title="Inicio | Portafolio">
	<section class="flex flex-col items-center text-center py-12" transition:animate="fade">
		<div class="w-32 h-32 bg-blue-500 rounded-full mb-6 overflow-hidden shadow-lg border-4 border-white dark:border-slate-800">
			<img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" alt="Avatar" />
		</div>
		<h1 class="text-5xl font-bold mb-4 tracking-tight text-slate-900 dark:text-white font-sans">Hola, Soy Tu Nombre</h1>
		<p class="text-lg text-slate-600 dark:text-slate-400 max-w-md mb-8 font-sans">
			Desarrollador Full Stack. Me gusta crear cosas web modernas usando Astro y Svelte.
		</p>
		
		<InteractiveHero client:load />

		<a href="/experiencia" class="mt-10 text-blue-600 dark:text-blue-400 font-medium flex items-center gap-2 group font-sans">
			Ver mi experiencia 
			<span class="group-hover:translate-x-1 transition-transform">→</span>
		</a>
	</section>
</Layout>