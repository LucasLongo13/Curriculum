---
// SECCIÓN DE SCRIPTS (Frontmatter)
// Aquí se importa el Layout principal que envuelve la página.
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto | Portafolio">
    
    <section class="max-w-xl mx-auto py-10" transition:animate="fade">
        
        <h1 class="text-4xl font-black mb-6 text-center text-slate-900 dark:text-white">
            ¡Hablemos!
        </h1>
        
        <p class="text-center text-slate-600 dark:text-slate-400 mb-12 text-lg">
            Estoy disponible para nuevas oportunidades. Elige el medio que prefieras:
        </p>

        <div class="flex flex-col gap-8">
            
            <div class="flex flex-col items-center p-8 bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm hover:border-[#0077b5]/50 transition-all text-center">
                
                <div class="p-4 bg-[#0077b5]/10 rounded-2xl mb-4 text-[#0077b5]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                </div>
                
                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-1">LinkedIn</h3>
                <p class="text-slate-900 dark:text-white font-semibold mb-6 text-lg">Perfil Profesional</p>
                
                <a href="https://www.linkedin.com/in/lucas-l-longo/?skipRedirect=true" target="_blank" rel="noopener noreferrer" class="w-full max-w-xs py-3 bg-[#0077b5] text-white rounded-xl font-bold hover:brightness-110 transition-all">
                    Conectar en LinkedIn
                </a>
            </div>

            <div class="flex flex-col items-center p-8 bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm hover:border-blue-500/50 transition-all text-center">
                <div class="p-4 bg-blue-50 dark:bg-blue-900/30 rounded-2xl mb-4 text-blue-600 dark:text-blue-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                </div>
                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-1">Email</h3>
                <p class="text-slate-900 dark:text-white font-semibold mb-6 text-lg">lucaslongo2030@gmail.com</p>
                
                <a href="mailto:lucaslongo2030@gmail.com" class="w-full max-w-xs py-3 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 transition-colors">
                    Enviar Correo
                </a>
            </div>

            <div class="flex flex-col items-center p-8 bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm hover:border-green-500/50 transition-all text-center">
                <div class="p-4 bg-green-50 dark:bg-green-900/30 rounded-2xl mb-4 text-green-600 dark:text-green-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </div>
                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-1">Teléfono</h3>
                <p class="text-slate-900 dark:text-white font-semibold mb-6 text-lg">+54 3491 691131</p>
                
                <a href="tel:+543491691131" class="w-full max-w-xs py-3 bg-green-600 text-white rounded-xl font-bold hover:bg-green-700 transition-colors">
                    Llamar Ahora
                </a>
            </div>
        </div>
    </section>
</Layout>