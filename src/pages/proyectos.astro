---
// SECCIÓN DE SCRIPTS (Frontmatter)
// Importamos el Layout base para mantener la consistencia del portafolio.
import Layout from "../layouts/Layout.astro";

// Definimos la lista de proyectos.
// Esto permite centralizar la información y facilitar futuras actualizaciones de tu perfil.
const proyectos = [
    {
        title: "Mi portafolio personal de GitHub",
        link: "https://github.com/LucasLongo13",
    },
];
---
<Layout title="Proyectos | Portafolio">
    <h1
        class="text-4xl font-black mb-12 text-center text-slate-900 dark:text-white"
        transition:name="title"
    >
        Mis Proyectos
    </h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
            proyectos.map((p) => (
                /* TARJETA DEL PROYECTO:
               - hover:shadow-xl: aumenta la sombra al pasar el mouse para dar profundidad*/
               
                <div class="bg-white dark:bg-slate-900 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-xl transition-all group">
                    <h3 class="text-2xl font-bold mb-2 text-slate-900 dark:text-white">
                        {p.title}
                    </h3>
                    <a
                        href={p.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 px-5 py-2 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-bold rounded-xl hover:scale-105 transition-transform"
                    >
                        <svg
                            xmlns="https://github.com/LucasLongo13"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <>
                                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                                <path d="M9 18c-4.51 2-4.51-2-7-2" />
                            </>
                        </svg>
                        Ver en GitHub
                    </a>
                </div>
            ))
        }
    </div>
</Layout>
