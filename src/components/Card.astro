---
// Define la estructura de las propiedades (props) que el componente acepta
interface Props {
	title: string;
	company: string;
	date: string;
	desc: string;
}

const { title, company, date, desc } = Astro.props;
---

<div class="group relative bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-800 hover:shadow-xl hover:border-blue-500/30 transition-all duration-500">
	<div class="absolute -left-[33px] top-10 w-4 h-4 bg-blue-600 rounded-full border-4 border-slate-50 dark:border-slate-950 group-hover:scale-150 transition-transform shadow-[0_0_15px_rgba(37,99,235,0.5)]"></div>
	
	<div class="flex flex-col md:flex-row md:justify-between md:items-start mb-4">
		<div>
			<h3 class="text-2xl font-bold text-slate-900 dark:text-white">{title}</h3>
			<p class="text-blue-600 dark:text-blue-400 font-semibold">{company}</p>
		</div>
		<span class="mt-2 md:mt-0 px-4 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 text-xs font-bold uppercase">
			{date}
		</span>
	</div>
	<p class="text-slate-600 dark:text-slate-400 leading-relaxed text-lg">{desc}</p>
</div>